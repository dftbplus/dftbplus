Geometry = GenFormat {
  <<< geo.gen
}

DisplayModes {
  Animate = No
}

SlaterKosterFiles = Type2FileNames {
  Prefix = "slakos/origin/mio-1-1/"
  Separator = "-"
  Suffix = ".skf"
}

Hessian = {
  <<< "hessian.out"
}

PhaseLock = Yes
DegenerateAt = 1E-20 # Very small, working around current state before rebasing

InputVersion = 3
