Geometry = GenFormat {
  <<< geo.gen
}

Atoms = O

DisplayModes {
  Animate = Yes
  PlotModes = 9:11
}

SlaterKosterFiles = Type2FileNames {
  Prefix = "slakos/origin/mio-1-1/"
  Separator = "-"
  Suffix = ".skf"
}

Hessian = {
  <<< "hessian.out.O"
}

PhaseLock = Yes
DegenerateAt = 1E-20 # Very small, working around current state before rebasing

InputVersion = 3
