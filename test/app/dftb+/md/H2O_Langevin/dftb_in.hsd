Geometry = GenFormat {
    3  C
    O H
    1    1    0.00000000000  -1.00000000000   0.00000000000
    2    2    0.00000000000   0.00000000000   0.78306400000
    3    2    0.00000000000   0.00000000000  -0.78306400000
}

Driver = VelocityVerlet {
    Steps = 10
    TimeStep [Femtosecond] = 0.1
    Thermostat = Langevin {
        Temperature [Kelvin] = 298
        TimeConstant [ps] = 16.7 # Approximately water self diffusion
    }
    OutputPrefix = "geo_end"
}

Hamiltonian = DFTB {
    MaxAngularMomentum = {
        O = "p"
        H = "s"
    }
    Filling = Fermi {
        Temperature [Kelvin] = 298
    }
    SlaterKosterFiles = Type2FileNames {
        Prefix = {slakos/origin/mio-1-1/}
        Separator = "-"
        Suffix = ".skf"
    }
}

Options = {
    WriteAutotestTag = Yes  
    RandomSeed = 31421
}

ParserOptions = {
    ParserVersion = 15
}

Parallel {
    # Allow OMP threads explicitely to test for hybrid parallelisation with
    # MPI-binary. (Check the manual before using this in production runs!)
    UseOmpThreads = Yes
}
