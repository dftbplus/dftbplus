Geometry = genFormat {
    <<< "geo.gen"
}

Driver = {}
Hamiltonian = DFTB {
    SCC = Yes
    SCCTolerance = 1e-8
    MaxAngularMomentum = {
        O = "p"
        C = "p"
        H = "s"
    }
    SlaterKosterFiles = Type2FileNames {
        Prefix = "slakos/origin/ob2-1-1/shift/"
        Separator = "-"
        Suffix = ".skf"
    }
    Hybrid = CAM {
      Screening = MatrixBased {}
    }
}
ExcitedState {
    Casida {
        TammDancoff = Yes
        NrOfExcitations = 10
        Symmetry = Singlet
        Diagonaliser = Stratmann{}
        StateCouplings = {0 4}
    }
}


Options {
    WriteAutotestTag = Yes
}

ParserOptions {
    ParserVersion = 13
}            

