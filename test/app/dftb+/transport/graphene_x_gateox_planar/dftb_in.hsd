Geometry = GenFormat {
<<< 'graphene.gen'
}


Transport {
    Device {
      AtomRange = 1 80
    FirstLayerAtoms =  1  17 33 49 65
    }
    Contact {
      Id = "source"
      AtomRange = 81 96
    FermiLevel [eV] =  -4.632043
      potential [eV] = 0.0
    }
    Contact {
      Id = "drain"
      AtomRange = 97 112
    FermiLevel [eV] =  -4.632043
      potential [eV] = 0.1
    }
  }


Driver = {}

Hamiltonian = DFTB {
  SCC = Yes
  SCCTolerance = 1e-7
  MaxAngularMomentum = {
    C = "p"
  }

  Filling = Fermi {
    Temperature [Kelvin] = 0
  }
  SlaterKosterFiles = Type2FileNames {
    Prefix = {slakos/origin/mio-1-1/}
    Separator = "-"
    Suffix = ".skf"
  }
  KpointsAndWeights = SupercellFolding{
    1 0 0
    0 1 0
    0 0 8
    0.0 0.0 0.0
  }
  Electrostatics = Poisson {
    MinimalGrid [Angstrom] = 0.4 0.4 0.4
    AtomDensityTolerance = 1e-5
    CutoffCheck = Yes   # Make sure you know what you are doing!
    BuildBulkPotential = No
    SavePotential = Yes
    PoissonAccuracy = 1e-5
    Verbosity=110
    BoxExtension [Angstrom]= 1.71
    BoundaryRegion = Square{
      BufferLength [Angstrom] = 3.0
    }
    Gate = Planar {
    GatePotential [eV] = 0.4
    GateLength_l [Angstrom] = 2.0
    GateLength_t [Angstrom] = 4.0
    GateDistance [Angstrom] = 10.0
    InsulatorLength_l [Angstrom] = 4.0
    InsulatorLength_t [Angstrom] = 6.0
    InsulatorDistance [Angstrom] = 8.0
    Permittivity = 5.0
    BufferLength [Angstrom] = 1.0
    GateDirection = 2
    }
  }

  Eigensolver = GreensFunction {
    ContourPoints = 30 42
    RealAxisPoints = 12
    LowestEnergy [eV] = -60.0
  }

  #ReadInitialCharges = yes

}

Analysis{
  TunnelingAndDOS{
    EnergyRange [eV] = -5.90  -4.00
    EnergyStep [eV] = 0.02
    Region = EachAtom {
      Atoms = 1:80
    }
  }
}

Options = {
  WriteAutotestTag = Yes
}

Parallel = {
  # Allow OMP threads explicitely to test for hybrid parallelisation with
  # MPI-binary. (Check the manual before using this in production runs!)
  UseOmpThreads = Yes
}

ParserOptions = {
  ParserVersion = 6
}
