Geometry = GenFormat {
<<< 'cnt_4pl.gen'
}

Transport {
    Device {
    AtomRange = 1 80
    FirstLayerAtoms = 1  41
    }
    Contact {
      Id = "source"
      AtomRange = 81 120
      FermiLevel [eV] = -4.370889992000
      potential = 0.0
    }
    Contact {
      Id = "drain"
      AtomRange = 121 160
      FermiLevel [eV] = -4.370889992000
      potential = 0.0
    }
  Task = UploadContacts{}
}

Driver = {}

Hamiltonian = DFTB {
  SCC = Yes
  MaxAngularMomentum = {
    C = "p"
  }
  Filling = Fermi {Temperature [Kelvin] = 0}
  SlaterKosterFiles = Type2FileNames {
    Prefix = {slakos/origin/mio-1-1/}
    Separator = "-"
    Suffix = ".skf"
  }
  Solver = GreensFunction {}

  Electrostatics = Poisson {
    Poissonbox [Angstrom] = 24 24.0 20.0
    MinimalGrid [Angstrom] = 0.4 0.4 0.4
    AtomDensityTolerance = 1e-5
    CutoffCheck = No
    SavePotential = Yes
    Gate = Cylindrical {
    GatePotential [eV] = 0.4
    GateLength [Angstrom] = 5
    GateRadius [Angstrom] = 11.5
    InsulatorLength [Angstrom] = 7.5
    InsulatorRadius [Angstrom] = 10
    Permittivity = 5.0
    }
  }
}

Options = {
  WriteAutotestTag = Yes
}

Parallel{
  # Allow OMP threads explicitely to test for hybrid parallelisation with
  # MPI-binary. (Check the manual before using this in production runs!)
  UseOmpThreads = Yes
}

ParserOptions = {
  ParserVersion = 6
}
