Geometry = GenFormat {
  6  C
  C H
    1  1    0.00000000   0.00000000  -0.67000000
    2  1    0.00000000   0.00000000   0.67000000
    3  2    0.00000000   0.93000000  -1.24000000
    4  2    0.00000000  -0.93000000  -1.24000000
    5  2    0.00000000   0.93000000   1.24000000
    6  2    0.00000000  -0.93000000   1.24000000
}

Driver = {}

Hamiltonian = DFTB {
  SCC = Yes
  SCCTolerance = 1.0E-10
  MaxAngularMomentum = {
    H = "s"
    C = "p"
  }
  SlaterKosterFiles = Type2FileNames {
    Prefix = "slakos/origin/mio-1-1/"
    Separator = "-"
    Suffix = ".skf"
  }
}

Options = {
  WriteAutotestTag = Yes
}

Analysis = {
  MullikenAnalysis = Yes
  WriteBondPopulation = Yes
  WriteBondEnergy = Yes
  WriteBondOrder = Yes
}

ParserOptions = {
  ParserVersion = 14
}
